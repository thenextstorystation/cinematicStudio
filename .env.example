# ---------------------------------------------------------------------------
# Cinematic Studio — environment configuration
# Copy to .env.local and fill in. Never commit real secrets.
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) ---------------------------------------------
# Pooled connection string from the Neon dashboard.
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/cinematic?sslmode=require"

# --- Auth (Clerk) ----------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# --- Billing (Stripe) ------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Price IDs for credit packs / subscription tiers (create in Stripe dashboard).
STRIPE_PRICE_CREATOR="price_..."
STRIPE_PRICE_PRO="price_..."

# --- Storage ---------------------------------------------------------------
# Choose the active provider: "cloudinary" | "synology"
STORAGE_PROVIDER="cloudinary"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Synology (self-hosted). Uses the WebDAV or S3-compatible endpoint of DSM.
SYNOLOGY_ENDPOINT="https://nas.example.com:5006"
SYNOLOGY_BUCKET="cinematic"
SYNOLOGY_ACCESS_KEY=""
SYNOLOGY_SECRET_KEY=""
SYNOLOGY_PUBLIC_BASE_URL="https://cdn.example.com"

# --- AI (Claude — co-writer & auto-breakdown, Module 1) -------------------
# https://console.anthropic.com — required for the AI co-writer and breakdown.
ANTHROPIC_API_KEY=""

# --- Generation providers (model adapters, "buy" side) --------------------
# Optional at this stage; adapters degrade gracefully when unset.
HIGGSFIELD_API_KEY=""

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
